# === LLM ===
# llama.cpp llama-server uses an OpenAI-compatible /v1 API.
LLM_HOST=http://localhost:8080/v1
LLM_MODEL=Qwen3-8B-Q4_K_M.gguf

# === Embedding / Reranker ===
EMBEDDING_HOST=http://localhost:8001
RERANKER_HOST=http://localhost:8002

# === Vector DB ===
QDRANT_HOST=http://qdrant:6333
QDRANT_COLLECTION=proposals
# RAG_COLLECTION is accepted as the domain-neutral alias for QDRANT_COLLECTION.
# RAG_COLLECTION=proposals

# === Plugins ===
RAG_ENABLED_PLUGINS=proposal
NEXT_PUBLIC_RAG_ENABLED_PLUGINS=proposal

# === Project Platform ===
PROJECT_DB_PATH=data/projects.sqlite3
SOURCE_INDEX_LOCK_TIMEOUT_SECONDS=3600
SOURCE_INDEX_API_TOKEN=
RAG_SOURCE_BASE_PATH=/opt/rag-projects
SVN_CHECKOUT_WEBHOOK_URL=http://host.docker.internal:8089

# === Auth ===
SECRET_KEY=change_this_to_a_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === App ===
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
NGINX_HTTP_PORT=80
